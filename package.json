{
  "name": "audit-assignment-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/secureAccessServer.mjs",
    "start": "node server/secureAccessServer.mjs",
    "secure": "npm run build && node server/secureAccessServer.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check": "tsc -b --pretty false",
    "test": "tsc -p tsconfig.test.json && node --test test-dist/tests/*.test.js tests/*.test.mjs"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.11.0",
    "jose": "^6.2.3",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest"
  }
}
